<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_esg_summary" model="ir.actions.report">
        <field name="name">ESG Summary Report</field>
        <field name="model">esg.department.score</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ecosphere_esg.report_esg_summary_document</field>
        <field name="report_file">ecosphere_esg.report_esg_summary_document</field>
        <field name="print_report_name">'ESG Summary Report'</field>
        <field name="binding_model_id" ref="model_esg_department_score"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_esg_summary_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>ESG Summary Report</h2>
                        <p><strong>Department:</strong> <span t-field="o.department_id.name"/></p>
                        <p><strong>Period:</strong> <span t-field="o.period_date"/></p>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Environmental Score</th>
                                    <th>Social Score</th>
                                    <th>Governance Score</th>
                                    <th>Overall ESG Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span t-field="o.environmental_score"/></td>
                                    <td><span t-field="o.social_score"/></td>
                                    <td><span t-field="o.governance_score"/></td>
                                    <td><strong><span t-field="o.total_score"/></strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
