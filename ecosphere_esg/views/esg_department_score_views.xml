<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_department_score_list" model="ir.ui.view">
        <field name="name">esg.department.score.list</field>
        <field name="model">esg.department.score</field>
        <field name="arch" type="xml">
            <list>
                <field name="department_id"/>
                <field name="period_date"/>
                <field name="environmental_score"/>
                <field name="social_score"/>
                <field name="governance_score"/>
                <field name="total_score"/>
            </list>
        </field>
    </record>
    <record id="view_esg_department_score_form" model="ir.ui.view">
        <field name="name">esg.department.score.form</field>
        <field name="model">esg.department.score</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_recompute_from_operational_data" type="object" string="Recompute" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="department_id"/>
                        <field name="period_date"/>
                        <field name="environmental_score"/>
                        <field name="social_score"/>
                        <field name="governance_score"/>
                        <field name="total_score" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_esg_department_score_graph" model="ir.ui.view">
        <field name="name">esg.department.score.graph</field>
        <field name="model">esg.department.score</field>
        <field name="arch" type="xml">
            <graph string="ESG Score Trend" type="line">
                <field name="period_date"/>
                <field name="total_score" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="action_esg_department_score" model="ir.actions.act_window">
        <field name="name">Department Scores</field>
        <field name="res_model">esg.department.score</field>
        <field name="view_mode">list,form,graph</field>
    </record>
</odoo>
