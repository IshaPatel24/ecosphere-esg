<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_product_profile_list" model="ir.ui.view">
        <field name="name">esg.product.profile.list</field>
        <field name="model">esg.product.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_id"/>
                <field name="carbon_footprint"/>
                <field name="recyclable"/>
                <field name="sustainable_material"/>
            </list>
        </field>
    </record>
    <record id="view_esg_product_profile_form" model="ir.ui.view">
        <field name="name">esg.product.profile.form</field>
        <field name="model">esg.product.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="carbon_footprint"/>
                        <field name="emission_factor_id"/>
                        <field name="recyclable"/>
                        <field name="sustainable_material"/>
                        <field name="esg_notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_esg_product_profile" model="ir.actions.act_window">
        <field name="name">Product ESG Profiles</field>
        <field name="res_model">esg.product.profile</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
