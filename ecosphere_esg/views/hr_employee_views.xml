<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_esg_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.esg.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="ESG &amp; Gamification">
                    <group>
                        <group>
                            <field name="esg_department_id"/>
                            <field name="xp"/>
                            <field name="points"/>
                        </group>
                        <group>
                            <field name="csr_completed_count"/>
                            <field name="challenge_completed_count"/>
                        </group>
                    </group>
                    <field name="badge_ids" widget="many2many_tags"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hr_employee_list_leaderboard" model="ir.ui.view">
        <field name="name">hr.employee.list.leaderboard</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <list string="Leaderboard" default_order="xp desc" create="false" edit="false">
                <field name="name"/>
                <field name="esg_department_id"/>
                <field name="xp"/>
                <field name="points"/>
                <field name="badge_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="action_esg_leaderboard" model="ir.actions.act_window">
        <field name="name">Leaderboard</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_hr_employee_list_leaderboard"/>
        <field name="domain">[('xp','>',0)]</field>
    </record>
</odoo>
