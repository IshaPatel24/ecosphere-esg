<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_employee_participation_list" model="ir.ui.view">
        <field name="name">esg.employee.participation.list</field>
        <field name="model">esg.employee.participation</field>
        <field name="arch" type="xml">
            <list decoration-success="approval_status=='approved'" decoration-danger="approval_status=='rejected'">
                <field name="employee_id"/>
                <field name="activity_id"/>
                <field name="completion_date"/>
                <field name="approval_status"/>
                <field name="points_earned"/>
                <button name="action_approve" type="object" string="Approve" icon="fa-check" invisible="approval_status != 'pending'"/>
                <button name="action_reject" type="object" string="Reject" icon="fa-times" invisible="approval_status != 'pending'"/>
            </list>
        </field>
    </record>
    <record id="view_esg_employee_participation_form" model="ir.ui.view">
        <field name="name">esg.employee.participation.form</field>
        <field name="model">esg.employee.participation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="approval_status != 'pending'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="approval_status != 'pending'"/>
                    <field name="approval_status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="activity_id"/>
                        <field name="proof" filename="proof_filename"/>
                        <field name="proof_filename" invisible="1"/>
                        <field name="points_earned" readonly="1"/>
                        <field name="completion_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_esg_employee_participation" model="ir.actions.act_window">
        <field name="name">Employee Participation</field>
        <field name="res_model">esg.employee.participation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
