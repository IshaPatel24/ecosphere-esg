<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_challenge_participation_list" model="ir.ui.view">
        <field name="name">esg.challenge.participation.list</field>
        <field name="model">esg.challenge.participation</field>
        <field name="arch" type="xml">
            <list decoration-success="approval=='approved'" decoration-danger="approval=='rejected'">
                <field name="employee_id"/>
                <field name="challenge_id"/>
                <field name="progress"/>
                <field name="approval"/>
                <field name="xp_awarded"/>
                <button name="action_approve" type="object" string="Approve" icon="fa-check" invisible="approval != 'pending'"/>
                <button name="action_reject" type="object" string="Reject" icon="fa-times" invisible="approval != 'pending'"/>
            </list>
        </field>
    </record>
    <record id="view_esg_challenge_participation_form" model="ir.ui.view">
        <field name="name">esg.challenge.participation.form</field>
        <field name="model">esg.challenge.participation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="approval != 'pending'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="approval != 'pending'"/>
                    <field name="approval" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="challenge_id"/>
                        <field name="progress"/>
                        <field name="proof" filename="proof_filename"/>
                        <field name="proof_filename" invisible="1"/>
                        <field name="xp_awarded" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_esg_challenge_participation" model="ir.actions.act_window">
        <field name="name">Challenge Participation</field>
        <field name="res_model">esg.challenge.participation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
