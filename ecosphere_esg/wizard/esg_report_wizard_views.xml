<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_report_wizard_form" model="ir.ui.view">
        <field name="name">esg.report.wizard.form</field>
        <field name="model">esg.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="report_type"/>
                    <field name="export_format"/>
                </group>
                <group string="Filters">
                    <group>
                        <field name="department_id"/>
                        <field name="employee_id"/>
                        <field name="challenge_id"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="esg_category"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" type="object" string="Generate Report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_esg_report_wizard" model="ir.actions.act_window">
        <field name="name">Custom Report Builder</field>
        <field name="res_model">esg.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
